# Exemplo de Configuração de Ambiente
# Copie este arquivo para .env.local e preencha os valores

# Backend API URL
ANGULAR_APP_API_URL=http://localhost:5000/api

# Ambiente
ANGULAR_APP_ENV=development

# Debug
ANGULAR_APP_DEBUG=true

# Configurações de Autenticação
ANGULAR_APP_TOKEN_STORAGE_KEY=authToken
ANGULAR_APP_REFRESH_TOKEN_KEY=refreshToken
ANGULAR_APP_USER_STORAGE_KEY=currentUser

# Configurações de API
ANGULAR_APP_API_TIMEOUT=30000
ANGULAR_APP_API_RETRY_ATTEMPTS=3
ANGULAR_APP_API_RETRY_DELAY=1000
